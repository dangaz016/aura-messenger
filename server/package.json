{
  "name": "aura-server",
  "version": "1.0.0",
  "description": "Aura Messenger backend - privacy-first messaging",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch --experimental-sqlite src/index.ts",
    "prebuild": "cd .. && npm --prefix client install && npm --prefix client run build",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:prod": "tsx --experimental-sqlite src/index.ts"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.1",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "socket.io": "^4.8.1",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.9.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
